generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AccountTitle {
  id           Int          @id @default(autoincrement())
  deletedAt    DateTime?
  label        String
  orgId        Int
  code         String?
  Organization Organization @relation(fields: [orgId], references: [id])
  GISRow       GISRow[]
  SummaryRow   SummaryRow[]

  @@unique([orgId, label])
}

model Agent {
  id                       String                     @id
  agentType                AgentType
  organizationId           Int?
  email                    String                     @unique
  phone                    String?
  passwordHash             String
  isVerified               Boolean                    @default(false)
  verificationStatus       VerificationStatus         @default(PENDING)
  trustTier                String                     @default("FREE")
  environment              Environment                @default(PRODUCTION)
  isDevSeed                Boolean                    @default(false)
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime
  deletedAt                DateTime?
  fullname                 String
  Organization             Organization?              @relation(fields: [organizationId], references: [id])
  AgentVerification        AgentVerification[]
  Mandate                  Mandate[]
  SupplierOrganizationLink SupplierOrganizationLink[]
  SupplierOutletLink       SupplierOutletLink[]

  @@index([agentType, verificationStatus])
  @@index([organizationId])
}

model AgentVerification {
  id           String             @id
  agentId      String
  documentType DocumentType
  fileUrl      String
  status       VerificationStatus @default(PENDING)
  reviewedById Int?
  reviewedAt   DateTime?
  environment  Environment        @default(PRODUCTION)
  createdAt    DateTime           @default(now())
  deletedAt    DateTime?
  Agent        Agent              @relation(fields: [agentId], references: [id])

  @@index([agentId, status])
}

model Attendance {
  id              Int              @id @default(autoincrement())
  deletedAt       DateTime?
  userId          Int
  shiftId         Int
  shiftDate       DateTime
  timeIn          DateTime?
  timeOut         DateTime?
  breakStart      DateTime?
  breakEnd        DateTime?
  photoIn         String?
  photoOut        String?
  photoBreakStart String?
  photoBreakEnd   String?
  status          AttendanceStatus @default(PRESENT)
  orgId           Int
  noteBreakEnd    String?
  noteBreakStart  String?
  noteIn          String?
  noteOut         String?
  Organization    Organization     @relation(fields: [orgId], references: [id])
  Shift           Shift            @relation(fields: [shiftId], references: [id])
  User            User             @relation(fields: [userId], references: [id])

  @@unique([userId, shiftDate])
  @@index([orgId, shiftDate])
  @@index([shiftId, shiftDate])
  @@index([userId, shiftDate])
}

model AuditLog {
  id         String      @id
  orgId      Int
  userId     Int
  pageKey    String
  action     AuditAction
  recordId   String?
  recordType String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  deletedAt  DateTime?
  User       User        @relation(fields: [userId], references: [id])
}

model Branch {
  id              Int               @id @default(autoincrement())
  name            String
  address         String
  phone           String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  deletedAt       DateTime?
  orgId           Int
  ownerId         Int
  locationId      Int?
  Organization    Organization      @relation(fields: [orgId], references: [id])
  User            User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  Contact         Contact[]
  Outlet          Outlet[]
  PlaceLocation   PlaceLocation?
  RestockCycle    RestockCycle[]
  RestockSchedule RestockSchedule[]
  SalesOrder      SalesOrder[]

  @@unique([orgId, name])
}

model Brand {
  id            Int          @id @default(autoincrement())
  deletedAt     DateTime?
  email         String?
  webUrl        String?
  contactNumber String?
  name          String       @unique
  orgId         Int
  Organization  Organization @relation(fields: [orgId], references: [id])
  Item          Item[]

  @@unique([orgId, name])
}

model Budget {
  id           Int          @id @default(autoincrement())
  year         Int
  account      String
  begBal       Float
  months       Json         @default("{}")
  orgId        Int
  userId       Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  deletedAt    DateTime?
  Organization Organization @relation(fields: [orgId], references: [id])
  User         User?        @relation(fields: [userId], references: [id])

  @@index([orgId, year])
}

model CartItem {
  transactionId     Int
  itemId            Int
  quantity          Float
  priceAtSale       Float              @default(0)
  unitId            Int?
  unitName          String?
  discountAmount    Float?             @default(0)
  discountQuantity  Float?             @default(0)
  discountRate      Float?             @default(0)
  discountType      DiscountType       @default(NONE)
  originalPrice     Float              @default(0)
  vatExclusivePrice Float              @default(0)
  finalPrice        Float              @default(0)
  costSnapshot      Float?
  priceSnapshot     Float?
  Item              Item               @relation(fields: [itemId], references: [id])
  Transaction       Transaction        @relation(fields: [transactionId], references: [id])
  InventoryItemUnit InventoryItemUnit? @relation(fields: [unitId], references: [id])

  @@id([transactionId, itemId])
}

model Center {
  id           Int          @id @default(autoincrement())
  deletedAt    DateTime?
  label        String
  orgId        Int
  Organization Organization @relation(fields: [orgId], references: [id])
  GISRow       GISRow[]
  SummaryRow   SummaryRow[]

  @@unique([orgId, label])
}

model Color {
  id        Int       @id @default(autoincrement())
  deletedAt DateTime?
  name      String    @unique
  hexCode   String?
  Item      Item[]    @relation("ColorToItem")
}

model Contact {
  id           Int          @id @default(autoincrement())
  orgId        Int
  branchId     Int?
  label        String
  name         String
  email        String
  phone        String?
  position     String?
  department   String?
  notes        String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  deletedAt    DateTime?
  Branch       Branch?      @relation(fields: [branchId], references: [id])
  Organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, branchId])
  @@index([orgId])
}

model CostLines {
  id        Int       @id @default(autoincrement())
  deletedAt DateTime?
  itemId    Int
  label     String
  amount    Float
  Item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Courier {
  id                     Int                      @id @default(autoincrement())
  name                   String
  phone                  String
  createdAt              DateTime                 @default(now())
  deletedAt              DateTime?
  KompraCOrder           KompraCOrder[]
  OrderCourierPreference OrderCourierPreference[]
  api_order              api_order[]
}

model CustomerDetails {
  id              Int         @id @default(autoincrement())
  deletedAt       DateTime?
  fullname        String?
  username        String?
  email           String?
  phoneNumber     String?
  paymentType     PaymentType
  paymentMethodId String?
  paymentIntentId String?
  client_key      String?
  status          String?
  transactionId   Int         @unique
  Transaction     Transaction @relation(fields: [transactionId], references: [id])
}

model CustomerDeviceToken {
  id             Int            @id @default(autoincrement())
  customerId     Int
  token          String         @unique
  platform       String
  createdAt      DateTime       @default(now())
  deletedAt      DateTime?
  KompraCustomer KompraCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Delivery {
  id            String         @id
  poId          String         @unique
  scheduledDate DateTime
  deliveredAt   DateTime?
  status        DeliveryStatus @default(SCHEDULED)
  driverName    String?
  driverContact String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  PurchaseOrder PurchaseOrder  @relation(fields: [poId], references: [id])
}

model DeliveryAddress {
  id             Int            @id @default(autoincrement())
  customerId     Int
  label          String
  address        String
  latitude       Float
  longitude      Float
  isDefault      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  deletedAt      DateTime?
  KompraCustomer KompraCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  KompraCOrder   KompraCOrder[]
}

model Department {
  id           Int          @id @default(autoincrement())
  deletedAt    DateTime?
  label        String
  color        String?
  orgId        Int
  Organization Organization @relation(fields: [orgId], references: [id])
  User         User[]

  @@unique([orgId, label])
}

model DiscountAudit {
  id                     String       @id
  orgId                  Int
  userId                 Int
  customerId             String?
  oscaGovId              String?
  itemId                 Int?
  salesOrderId           String?
  transactionId          Int?
  kompraOrderId          Int?
  customItemName         String?
  discountType           DiscountType
  discountAmount         Float
  eligibleAmount         Float?
  runningWeeklyBnpcTotal Float?
  isVoided               Boolean      @default(false)
  voidedAt               DateTime?
  voidReason             String?
  createdAt              DateTime     @default(now())
  deletedAt              DateTime?
  Item                   Item?        @relation(fields: [itemId], references: [id])
  User                   User         @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([customerId, createdAt])
  @@index([customerId])
  @@index([kompraOrderId])
  @@index([oscaGovId, createdAt])
  @@index([oscaGovId])
  @@index([salesOrderId])
  @@index([transactionId])
}

model Employee {
  id           String         @id
  deletedAt    DateTime?
  name         String
  role         String
  department   String
  status       EmployeeStatus
  salary       Float
  hireDate     DateTime       @default(now())
  email        String         @unique
  orgId        Int
  userId       Int?
  Organization Organization   @relation(fields: [orgId], references: [id])
  User         User?          @relation(fields: [userId], references: [id])

  @@unique([orgId, email])
  @@index([department])
  @@index([orgId])
}

model EscrowRelease {
  id                   String             @id
  mandateTransactionId String             @unique
  buyerProofUrl        String?
  sellerProofUrl       String?
  buyerConfirmedAt     DateTime?
  sellerConfirmedAt    DateTime?
  autoReleaseAt        DateTime?
  releasedAt           DateTime?
  disputeStatus        DisputeStatus      @default(NONE)
  disputeReason        String?
  resolvedById         Int?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  MandateTransaction   MandateTransaction @relation(fields: [mandateTransactionId], references: [id])
}

model ExtraCharge {
  id           String     @id
  label        String
  amount       Float
  salesOrderId String
  createdAt    DateTime   @default(now())
  deletedAt    DateTime?
  SalesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([salesOrderId])
}

model FeeRule {
  id            String         @id
  appliesTo     FeeApplication
  category      String?
  unitType      String?
  rateType      FeeRateType
  rate          Float
  tierModifier  Float?         @default(0)
  effectiveFrom DateTime       @default(now())
  effectiveTo   DateTime?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  deletedAt     DateTime?

  @@index([appliesTo, category, unitType, isActive])
}

model GISRow {
  main           String
  group          String
  code           String
  description    String
  debit          Float
  credit         Float
  total          Float
  orgId          Int
  userId         Int?
  createdAt      DateTime     @default(now())
  deletedAt      DateTime?
  accountTitleId Int
  centerId       Int
  subCenterId    Int
  id             Int          @id @unique @default(autoincrement())
  AccountTitle   AccountTitle @relation(fields: [accountTitleId], references: [id])
  Center         Center       @relation(fields: [centerId], references: [id])
  Organization   Organization @relation(fields: [orgId], references: [id])
  SubCenter      SubCenter    @relation(fields: [subCenterId], references: [id])
  User           User?        @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt])
  @@index([orgId])
}

model Inventory {
  id             Int              @id @default(autoincrement())
  deletedAt      DateTime?
  name           String?
  outletId       Int              @unique
  Outlet         Outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade)
  InventoryItems InventoryItems[]
}

model InventoryItem {
  id           String       @id
  deletedAt    DateTime?
  name         String
  sku          String
  stock        Int
  minStock     Int
  category     String
  price        Float
  lowStock     Boolean
  orgId        Int
  userId       Int?
  Organization Organization @relation(fields: [orgId], references: [id])
  User         User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
}

model InventoryItemUnit {
  id               Int                @id @default(autoincrement())
  deletedAt        DateTime?
  inventoryItemId  Int
  unitName         String
  unitLabel        String
  price            Float
  quantity         Float              @default(0)
  conversionFactor Float              @default(1)
  baseUnit         String             @default("piece")
  barcode          String?
  isDefault        Boolean            @default(false)
  isActive         Boolean            @default(true)
  minOrderQty      Float?
  maxOrderQty      Float?
  reorderPoint     Float?
  allowDecimal     Boolean            @default(false)
  CartItem         CartItem[]
  InventoryItems   InventoryItems     @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  KompraCOrderItem KompraCOrderItem[]

  @@unique([inventoryItemId, unitName])
  @@index([inventoryItemId])
}

model InventoryItems {
  id                    Int                    @id @default(autoincrement())
  deletedAt             DateTime?
  inventoryId           Int
  itemId                Int
  price                 Float
  quantity              Int                    @default(0)
  locationId            Int?                   @unique
  categoryId            Int?
  baseUnit              String                 @default("piece")
  InventoryItemUnit     InventoryItemUnit[]
  ItemCategory          ItemCategory?          @relation(fields: [categoryId], references: [id])
  Inventory             Inventory              @relation(fields: [inventoryId], references: [id])
  Item                  Item                   @relation(fields: [itemId], references: [id])
  Location              Location?              @relation(fields: [locationId], references: [id], onDelete: Cascade)
  KompraCOrderItem      KompraCOrderItem[]
  OutletItemSearchIndex OutletItemSearchIndex?

  @@unique([inventoryId, itemId])
}

model Item {
  id                         Int                     @id @default(autoincrement())
  deletedAt                  DateTime?
  name                       String                  @unique
  image                      String?
  description                String?
  barcode                    String
  brand                      String?
  orgId                      Int
  categoryId                 Int?
  brandId                    Int?
  ServiceCharge              Boolean                 @default(false)
  assembly                   Boolean                 @default(false)
  itemCode                   String?
  skuNumber                  String?
  vatExempt                  Boolean?
  isVatExempt                Boolean                 @default(false)
  isBNPC                     Boolean                 @default(false)
  hasSeniorDiscountVATExempt Boolean                 @default(false)
  vatRate                    Float                   @default(0.12)
  stock                      Float                   @default(0)
  sellingPrice               Float                   @default(0)
  minQuantity                Float                   @default(0)
  opExPct                    Float                   @default(0.1)
  priceB                     Float?
  priceC                     Float?
  totalCost                  Float                   @default(0)
  expiryEndDate              DateTime?
  expiryStartDate            DateTime?
  exactExpiryDate            DateTime?
  orgCategoryId              Int?
  vatTypeId                  Int?
  stockDescription           String?
  stockLabel                 String?
  CartItem                   CartItem[]
  CostLines                  CostLines[]
  DiscountAudit              DiscountAudit[]
  InventoryItems             InventoryItems[]
  Brand                      Brand?                  @relation(fields: [brandId], references: [id])
  ItemCategory               ItemCategory?           @relation(fields: [categoryId], references: [id])
  OrgItemCategory            OrgItemCategory?        @relation(fields: [orgCategoryId], references: [id])
  Organization               Organization            @relation(fields: [orgId], references: [id])
  VatType                    VatType?                @relation(fields: [vatTypeId], references: [id])
  ItemCategoryMap            ItemCategoryMap[]
  ItemCostHistory            ItemCostHistory[]
  ItemPriceHistory           ItemPriceHistory[]
  KompraCOrderItem           KompraCOrderItem[]
  Media                      Media[]
  Notification               Notification[]
  OutletItemSearchIndex      OutletItemSearchIndex[]
  ReceivedItemMap            ReceivedItemMap[]
  RestockCycleItem           RestockCycleItem[]
  RestockScheduleItem        RestockScheduleItem[]
  SalesOrderItem             SalesOrderItem[]
  StockBatch                 StockBatch[]
  StockMovement              StockMovement[]
  SummaryRow                 SummaryRow[]
  SupplierOrderItem          SupplierOrderItem[]
  Color                      Color[]                 @relation("ColorToItem")
  ItemUnit                   ItemUnit[]              @relation("ItemToItemUnit")

  @@unique([orgId, name])
}

model ItemCategory {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  description     String?
  groupType       String?
  sales           String?
  stocks          String?
  createdAt       DateTime          @default(now())
  deletedAt       DateTime?
  icon            String?
  InventoryItems  InventoryItems[]
  Item            Item[]
  OrgItemCategory OrgItemCategory[]
}

model ItemCategoryMap {
  itemId          Int
  categoryId      Int
  OrgItemCategory OrgItemCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  Item            Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([itemId, categoryId])
}

model ItemCostHistory {
  id          Int      @id @default(autoincrement())
  itemId      Int
  totalCost   Float
  costLines   Json
  effectiveAt DateTime @default(now())
  changedBy   Int?
  reason      String?
  Item        Item     @relation(fields: [itemId], references: [id])
}

model ItemGroup {
  id              Int               @id @default(autoincrement())
  name            String
  description     String?
  icon            String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  deletedAt       DateTime?
  orgId           Int
  Organization    Organization      @relation(fields: [orgId], references: [id])
  OrgItemCategory OrgItemCategory[]

  @@unique([orgId, name])
}

model SearchQuery {
  id             String    @id @default(cuid())
  term           String
  normalizedTerm String
  userId         Int?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  @@index([normalizedTerm, createdAt])
  @@index([createdAt])
}

model ItemPriceHistory {
  id             Int           @id @default(autoincrement())
  itemId         Int
  price          Float
  effectiveAt    DateTime      @default(now())
  changedBy      Int?
  reason         String?
  supplierItemId String?
  Item           Item          @relation(fields: [itemId], references: [id])
  SupplierItem   SupplierItem? @relation(fields: [supplierItemId], references: [id])

  @@index([itemId, effectiveAt])
}

model ItemUnit {
  id          Int       @id @default(autoincrement())
  deletedAt   DateTime?
  unitName    String    @unique
  description String?
  Item        Item[]    @relation("ItemToItemUnit")
}

model KompraCDeliveryTracking {
  id           Int                 @id @default(autoincrement())
  deletedAt    DateTime?
  orderId      Int
  event        DeliveryStatusEvent
  statusAt     DateTime            @default(now())
  currentLat   Float?
  currentLng   Float?
  note         String?
  actorType    String
  actorId      Int?
  KompraCOrder KompraCOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, statusAt])
}

model KompraCOrder {
  id                      Int                       @id @default(autoincrement())
  transactionNumber       String                    @unique
  customerId              Int
  outletId                Int
  deliveryAddressId       Int
  subtotal                Float
  total                   Float
  status                  OrderStatus               @default(pending)
  scheduledDeliveryAt     DateTime?
  estimatedDeliveryAt     DateTime?
  deliveredAt             DateTime?
  paymentMethod           KompraCPaymentMethod
  paymentStatus           String                    @default("unpaid")
  paymentReference        String?
  riderName               String?
  riderPhone              String?
  customerNote            String?
  outletNote              String?
  cancelNote              String?
  createdAt               DateTime                  @default(now())
  packedAt                DateTime?
  shippedAt               DateTime?
  placedAt                DateTime?
  cancelledAt             DateTime?
  updatedAt               DateTime
  inventoryDeductedAt     DateTime?
  deletedAt               DateTime?
  courierId               Int?
  scPwdCustomerId         String?
  customerType            CustomerType?             @default(REGULAR)
  discountType            DiscountType?             @default(NONE)
  scPwdPax                Int?
  totalPax                Int?
  vatExemptSale           Float?                    @default(0)
  discountAmount          Float?                    @default(0)
  vatAmount               Float?                    @default(0)
  grandTotal              Float?
  checkoutGroupId         String?
  KompraCDeliveryTracking KompraCDeliveryTracking[]
  Courier                 Courier?                  @relation(fields: [courierId], references: [id])
  KompraCustomer          KompraCustomer            @relation(fields: [customerId], references: [id])
  DeliveryAddress         DeliveryAddress           @relation(fields: [deliveryAddressId], references: [id])
  Outlet                  Outlet                    @relation(fields: [outletId], references: [id])
  ScPwdCustomer           ScPwdCustomer?            @relation(fields: [scPwdCustomerId], references: [id])
  KompraCOrderFee         KompraCOrderFee[]
  KompraCOrderItem        KompraCOrderItem[]
  OrderCourierPreference  OrderCourierPreference[]

  @@index([scPwdCustomerId])
}

model KompraCOrderFee {
  id           Int          @id @default(autoincrement())
  deletedAt    DateTime?
  orderId      Int
  type         FeeType
  label        String
  amount       Float
  KompraCOrder KompraCOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model KompraCOrderItem {
  id                Int                @id @default(autoincrement())
  deletedAt         DateTime?
  orderId           Int
  inventoryItemId   Int
  itemId            Int
  quantity          Int
  priceSnapshot     Float
  subtotal          Float
  unitId            Int?
  costSnapshot      Float?
  InventoryItems    InventoryItems     @relation(fields: [inventoryItemId], references: [id])
  Item              Item               @relation(fields: [itemId], references: [id])
  KompraCOrder      KompraCOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  InventoryItemUnit InventoryItemUnit? @relation(fields: [unitId], references: [id])

  @@unique([orderId, inventoryItemId])
}

model KompraCustomer {
  id                  Int                   @id @default(autoincrement())
  fullname            String
  email               String                @unique
  passwordHash        String
  profilePhoto        String?
  isVerified          Boolean               @default(false)
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  deletedAt           DateTime?
  phone               String?               @unique
  CustomerDeviceToken CustomerDeviceToken[]
  DeliveryAddress     DeliveryAddress[]
  KompraCOrder        KompraCOrder[]
}

model Location {
  id             Int             @id @default(autoincrement())
  deletedAt      DateTime?
  aisle          String?
  rack           String?
  shelf          String?
  InventoryItems InventoryItems?
}

model Mandate {
  id                 String              @id
  agentId            String
  category           String
  unitType           String
  quantity           Float
  targetPrice        Float?
  latitude           Float?
  longitude          Float?
  radiusKm           Float?              @default(10)
  status             MandateStatus       @default(DRAFT)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime
  deletedAt          DateTime?
  Agent              Agent               @relation(fields: [agentId], references: [id])
  MandateOffer       MandateOffer[]
  MandateTransaction MandateTransaction?

  @@index([agentId, status])
  @@index([category, unitType])
}

model MandateOffer {
  id            String             @id
  mandateId     String
  supplierOrgId Int
  price         Float
  availableQty  Float
  terms         String?
  status        MandateOfferStatus @default(PENDING)
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime
  deletedAt     DateTime?
  Mandate       Mandate            @relation(fields: [mandateId], references: [id])
  Organization  Organization       @relation(fields: [supplierOrgId], references: [id])

  @@index([mandateId, status])
  @@index([supplierOrgId, status])
}

model MandateTransaction {
  id                   String                   @id
  mandateId            String                   @unique
  offerId              String
  agentId              String
  supplierOrgId        Int
  amount               Float
  feeAmount            Float
  netAmount            Float
  settlementType       SettlementType           @default(INSTANT)
  status               MandateTransactionStatus @default(PENDING)
  paymentTransactionId String?
  linkedPoId           String?
  environment          Environment              @default(PRODUCTION)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime
  deletedAt            DateTime?
  EscrowRelease        EscrowRelease?
  Mandate              Mandate                  @relation(fields: [mandateId], references: [id])
  Organization         Organization             @relation(fields: [supplierOrgId], references: [id])

  @@index([agentId, status])
